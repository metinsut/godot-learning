extends Node

## Expert Checkpoint Manager (Godot 4.6).
## Atomic JSON persistence to prevent file corruption.

func save_state(data: Dictionary) -> void:
	var json = JSON.stringify(data)
	var path = "user://checkpoint.save"
	var tmp_path = path + ".tmp"
	
	# 1. WRITE to temporary file
	var file = FileAccess.open(tmp_path, FileAccess.WRITE)
	if file:
		file.store_line(json)
		file.close() # Ensure buffer is flushed
		
		# 2. ATOMIC SWAP: Rename tmp to final
		DirAccess.remove_absolute(path)
		DirAccess.rename_absolute(tmp_path, path)

func load_state() -> Dictionary:
	var path = "user://checkpoint.save"
	if not FileAccess.file_exists(path): return {}
	
	var file = FileAccess.open(path, FileAccess.READ)
	var json_data = JSON.parse_string(file.get_as_text())
	return json_data if json_data else {}

## [SKILL NOTICE]: Renaming a '.tmp' file is the professional way to 
## ensure the user never loses their save if the game crashes during writing.
