extends Node

## Expert Endless Generator (Godot 4.6).
## Exponential scaling with performance budget throttling.

@export var base_budget: float = 50.0
@export var scale_factor: float = 1.2
@export var mob_cap: int = 100

func generate_wave(idx: int) -> Dictionary:
	var budget = base_budget * pow(scale_factor, idx)
	var spawned = 0
	var stat_buff = 1.0
	
	# Generate...
	# If budget > mob_cap, convert remainder to stat_buff
	if budget > mob_cap * 5: # Arbitrary threshold
		stat_buff += (budget / 1000.0)
		budget = mob_cap * 5
	
	return {"budget": budget, "multiplier": stat_buff}

## [SKILL NOTICE]: Throttling is MANDATORY for endless games. 
## Convert excess budget into 'Quality' (Stats) to protect 'Quantity' (FPS).
