class_name AbilityControllerNode
extends Node

## Expert Ability Controller (Godot 4.6).
## Manages unique Resource instances per node.

@export var ability_resource: ResourceAbilityBase

func _ready() -> void:
	if ability_resource:
		# EXPERT PATTERN: duplicate() ensures this node has its own 
		# unique cooldown state, separate from other entities.
		ability_resource = ability_resource.duplicate()

func _process(delta: float) -> void:
	if ability_resource:
		ability_resource.process_cooldown(delta)

func activate() -> void:
	if ability_resource:
		ability_resource.execute(get_parent())

## [SKILL NOTICE]: Always duplicate resources that store 'internal state' 
## (cooldowns, ammo, HP) to avoid unintended global sharing.
