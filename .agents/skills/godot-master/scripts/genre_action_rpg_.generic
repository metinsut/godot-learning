class_name ActionStateMachine
extends Node

## Expert FSM for Action RPGs (Godot 4.6).
## Hierarchical Node-based delegation with AnimationTree support.

@export var initial_state: NodePath
@onready var state: Node = get_node(initial_state)

func _ready() -> void:
	for child in get_children():
		child.player = get_parent()
		child.fsm = self
	state.enter()

func _physics_process(delta: float) -> void:
	state.physics_process(delta)

func transition_to(target: String, msg: Dictionary = {}) -> void:
	if not has_node(target): return
	state.exit()
	state = get_node(target)
	state.enter(msg)

## [SKILL NOTICE]: Each child node should extend a base 'State' class. 
## Use 'AnimationNodeStateMachinePlayback' travel() for smooth transitions.
