class_name GhostDataResource
extends Resource

## Expert Ghost Data (Godot 4.6).
## Optimized storage for transform playback using Packed Arrays.

@export var timestamps: PackedFloat32Array = []
@export var positions: PackedVector3Array = []
@export var rotations: PackedVector4Array = [] # Stored as Quaternions (x, y, z, w)

func record_frame(time: float, pos: Vector3, rot: Quaternion) -> void:
	timestamps.append(time)
	positions.append(pos)
	rotations.append(Vector4(rot.x, rot.y, rot.z, rot.w))

func get_interpolated_transform(time: float) -> Transform3D:
	if timestamps.is_empty(): return Transform3D()
	
	# Binary search for the bounding frames
	var idx = timestamps.bsearch(time)
	if idx <= 0: return _at(0)
	if idx >= timestamps.size(): return _at(timestamps.size() - 1)
	
	var t0 = timestamps[idx-1]
	var t1 = timestamps[idx]
	var factor = (time - t0) / (t1 - t0)
	
	var pos = positions[idx-1].lerp(positions[idx], factor)
	var rot = _q(idx-1).slerp(_q(idx), factor)
	return Transform3D(Basis(rot), pos)

func _at(idx: int) -> Transform3D:
	return Transform3D(Basis(_q(idx)), positions[idx])

func _q(idx: int) -> Quaternion:
	var v = rotations[idx]
	return Quaternion(v.x, v.y, v.z, v.w)

## [SKILL NOTICE]: PackedVector4Array is the most efficient way 
## to store Quaternions for high-frequency transform recording.
