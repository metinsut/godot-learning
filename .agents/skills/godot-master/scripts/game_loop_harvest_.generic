class_name CropDataResource
extends Resource

## Expert Crop Data (Godot 4.6).
## Master resource defining harvesting requirements and yields.

@export var crop_name: String = "Wheat"
@export var stages: Array[CropStageResource] = []
@export var yield_item: Resource # Reference to ItemData resource
@export var yield_amount: int = 1

## [SKILL NOTICE]: Link this to an 'ItemData' resource from your 
## inventory skill to maintain strict architectural decoupling.
